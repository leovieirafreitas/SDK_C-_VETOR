<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="11.0" ExtensionBundleId="com.gradfixer.splitlayer" ExtensionBundleVersion="1.0.0" ExtensionBundleName="Grad Fixer Split" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.gradfixer.splitlayer.panel" Version="1.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[24.0,99.9]" />
            <Host Name="AEFT" Version="[22.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.gradfixer.splitlayer.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>FlashFill</Menu>
                    <Geometry>
                        <Size>
                            <Height>400</Height>
                            <Width>250</Width>
                        </Size>
                        <MinSize>
                            <Height>150</Height>
                            <Width>150</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>3000</Height>
                            <Width>3000</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
