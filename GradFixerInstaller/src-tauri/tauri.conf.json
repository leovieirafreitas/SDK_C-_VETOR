{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlashFill",
  "version": "1.0.7",
  "identifier": "com.flashfill.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FlashFill Setup",
        "width": 820,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/AEGP/GradientManipulator.aex": "resources/AEGP/GradientManipulator.aex",
      "../resources/AEGP/grad_batch_template.aepx": "resources/AEGP/grad_batch_template.aepx",
      "../resources/AEGP/grad_batch_template_1000.aepx": "resources/AEGP/grad_batch_template_1000.aepx",
      "../resources/AEGP/nested_group_template.aepx": "resources/AEGP/nested_group_template.aepx",
      "../resources/AEGP/nested_group_template_1000.aepx": "resources/AEGP/nested_group_template_1000.aepx",
      "../resources/GradFixer": "resources/GradFixer"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
